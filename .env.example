# Copy to .env and fill in. NEVER commit .env.

# Server
PORT=4000
NODE_ENV=development

# Blockchain (Sepolia)
SEPOLIA_RPC_URL=https://eth-sepolia.g.alchemy.com/v2/YOUR_KEY
# Validator wallet private key (authorized in the contract to register proofs)
VALIDATOR_PRIVATE_KEY=0x...
# Deployed ProofOfHumanity address (from poh-contracts deploy)
CONTRACT_ADDRESS=0x...

# PostgreSQL
DATABASE_URL=postgres://poh:poh@localhost:5432/poh

# Off-chain biometric validation threshold (0-1, lower distance = same face)
FACE_MATCH_THRESHOLD=0.6
